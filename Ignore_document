pythonfrom selenium.webdriver.common.action_chains import ActionChains
from selenium.webdriver.common.keys import Keys

class BasePage:

    def __init__(self, driver):
        self.driver = driver
        self.wait = WebDriverWait(driver, 10)
        self.actions = ActionChains(driver)   # ← add this

    # ─────────────────────────────────────────
    # MOUSE ACTIONS
    # ─────────────────────────────────────────

    def hover(self, locator):
        """Hover over an element — triggers dropdown menus"""
        element = self.find_element(locator)
        self.actions.move_to_element(element).perform()

    def double_click(self, locator):
        """Double click an element"""
        element = self.find_element(locator)
        self.actions.double_click(element).perform()

    def right_click(self, locator):
        """Right click — context menu"""
        element = self.find_element(locator)
        self.actions.context_click(element).perform()

    def drag_and_drop(self, source_locator, target_locator):
        """Drag element from source and drop on target"""
        source = self.find_element(source_locator)
        target = self.find_element(target_locator)
        self.actions.drag_and_drop(source, target).perform()

    def slow_type(self, locator, text):
        """Type character by character — useful for autocomplete fields"""
        element = self.find_element(locator)
        element.clear()
        for char in text:
            element.send_keys(char)

    # ─────────────────────────────────────────
    # KEYBOARD ACTIONS
    # ─────────────────────────────────────────

    def press_enter(self, locator):
        """Press Enter key on an element"""
        self.find_element(locator).send_keys(Keys.ENTER)

    def press_tab(self, locator):
        """Press Tab to move focus to next field"""
        self.find_element(locator).send_keys(Keys.TAB)

    def press_escape(self):
        """Press Escape — closes modals/dropdowns"""
        self.actions.send_keys(Keys.ESCAPE).perform()

    def select_all_and_delete(self, locator):
        """Ctrl+A then Delete — clear a field completely"""
        element = self.find_element(locator)
        element.send_keys(Keys.CONTROL + "a")
        element.send_keys(Keys.DELETE)

    def scroll_down(self, pixels=500):
        """Scroll down by pixels"""
        self.driver.execute_script(
            f"window.scrollBy(0, {pixels});"
        )

    def scroll_to_bottom(self):
        """Scroll to bottom of page"""
        self.driver.execute_script(
            "window.scrollTo(0, document.body.scrollHeight);"
        )

