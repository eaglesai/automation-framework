pythonimport configparser
import os
from selenium.webdriver.common.by import By


class LocatorReader:
    """
    Reads locators from locators.properties file.
    Automatically detects locator type:
    - starts with // or ( → XPath
    - otherwise → CSS Selector
    - plain word with no special chars → ID
    """

    _locators = {}

    @classmethod
    def load(cls, filepath="config/locators.properties"):
        config = configparser.ConfigParser()

        # configparser needs a section header — add a dummy one
        with open(filepath, 'r') as f:
            content = '[locators]\n' + f.read()

        config.read_string(content)
        cls._locators = dict(config['locators'])

    @classmethod
    def get(cls, key):
        if not cls._locators:
            cls.load()

        value = cls._locators.get(key.lower())
        if not value:
            raise KeyError(
                f"Locator '{key}' not found in locators.properties"
            )

        # Auto-detect locator type
        if value.startswith("//") or value.startswith("(//"):
            return (By.XPATH, value)
        elif any(c in value for c in ['.', '[', '#', '>', ' ']):
            return (By.CSS_SELECTOR, value)
        else:
            return (By.ID, value)
