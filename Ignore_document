            (By.CSS_SELECTOR,
             "img[alt='Website for automation practice']")
        )

    def is_hero_banner_visible(self):
        return self.is_displayed(self.HERO_BANNER)

    def search_product(self, product_name):
        self.type_text(self.SEARCH_INPUT, product_name)
        self.click(self.SEARCH_BTN)

